<main class="todo-shell">
			<div class="railshx-flash" data-railshx-flash role="status" aria-live="polite" hidden></div>
			<section class="hero">
				<div class="card">
					<span class="eyebrow">RailsHx sample</span>
					<h1>Typed Rails, polished Ruby.</h1>
					<p class="hero-copy">
						This todo app is authored in Haxe with typed ActiveRecord metadata,
						strong params, route helpers, and a Haxe-owned Rails template artifact.
					</p>
				</div>

				<aside class="card" aria-label="Todo stats">
					<div class="stat">
						<strong><%= todo_count %></strong>
						<span>open tasks</span>
					</div>
					<div class="stat">
						<strong><%= typed_column_count %></strong>
						<span>typed columns</span>
					</div>
				</aside>
			</section>

			<section class="workspace">
				<div class="card">
					<h2>Add a task</h2>
					<%= render partial: "controllers/todos/composer", locals: {sample_user: sample_user} %>
				</div>

				<div id="open-work" class="card open-work-card" tabindex="-1">
					<h2>Open work</h2>
					<%= render partial: "controllers/todos/list", locals: {todos: todos} %>
				</div>
			</section>

			<%= render partial: "controllers/todos/dashboard", locals: {todos: todos, todo_count: todo_count, typed_column_count: typed_column_count, sample_user: sample_user} %>
		</main>

  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "fflate": "0.8.3",
    "lix": "^15.12.4",
    "semantic-release": "^24.2.5",
    "semver": "7.8.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fullofcaffeine/reflaxe.ruby.git"
  },
  "release": {
    "branches": [
      "main"
    ],
    "tagFormat": "v${version}",
    "plugins": [
      [
        "./scripts/release/analyze-commits.mjs",
        {
          "approvedStableMajors": []
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "node scripts/release/prepare-release-artifacts.js ${nextRelease.version} ${nextRelease.gitTag} ${nextRelease.gitHead}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "releaseNameTemplate": "v${nextRelease.version}",
          "releaseBodyTemplate": "## v${nextRelease.version}\n\n${nextRelease.notes}",
          "assets": [
            {
              "path": "dist/reflaxe.ruby-release.zip",
              "name": "reflaxe.ruby-${nextRelease.version}.zip",
              "label": "reflaxe.ruby ${nextRelease.version} haxelib package"
            },
            {
              "path": "dist/hxruby-release.gem",
              "name": "hxruby-${nextRelease.version}.gem",
              "label": "hxruby ${nextRelease.version} Ruby gem"
            },
            {
              "path": "dist/reflaxe.ruby-release.zip.sha256.json",
              "name": "reflaxe.ruby-${nextRelease.version}.zip.sha256.json",
              "label": "reflaxe.ruby ${nextRelease.version} SHA-256 metadata"
            },
            {
              "path": "dist/hxruby-release.gem.sha256.json",
              "name": "hxruby-${nextRelease.version}.gem.sha256.json",
              "label": "hxruby ${nextRelease.version} SHA-256 metadata"
            }
          ]
        }
      ]
    ]
  }
}
